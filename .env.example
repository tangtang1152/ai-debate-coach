APP_NAME=ai-debate-coach-backend
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000

DATABASE_URL=sqlite:///storage/debate_coach.db
TEST_DATABASE_URL=sqlite:///:memory:

MAX_DEBATE_ROUNDS=3
PROMPT_HISTORY_LIMIT=6
MOCK_STREAM_CHUNK_SIZE=24
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

LLM_PROVIDER=openrouter
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
LLM_FALLBACK_MODELS=tencent/hy3-preview:free,google/gemma-4-31b-it:free
LLM_SELECTABLE_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,tencent/hy3-preview:free,google/gemma-4-31b-it:free,qwen/qwen3-coder:free
LLM_TIMEOUT_SECONDS=60
LLM_DEBATE_MAX_TOKENS=320
LLM_EVALUATION_MAX_TOKENS=500
LLM_REASONING_EFFORT=none
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5173
OPENROUTER_APP_TITLE=AI Debate Coach
